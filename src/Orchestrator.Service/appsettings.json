// =====================================================================================
// FILE PURPOSE (in plain terms):
//   The service's default settings file. At install time the installer overwrites
//   this with your real repo + token. The service reads it on startup to know which
//   GitHub repo to watch, how often, and where to install things. (JSON normally
//   forbids comments, but .NET's configuration reader ignores // comments, so they're
//   safe here.)
// =====================================================================================
{
  "Orchestrator": {
    "RootPath": "C:\\Orchestrator",                    // base folder the service installs into and works out of
    "RepoOwner": "YOUR_GITHUB_USER_OR_ORG",            // GitHub owner of your control repo (replaced at install)
    "RepoName": "orchestrator-repo",                   // name of your control repo (replaced at install)
    "Branch": "main",                                  // which branch of that repo to read
    "ManifestPath": "manifest.json",                   // path to the manifest file inside the repo
    "GitHubToken": "",                                 // access token for private repos (blank = public)
    "SyncIntervalMinutes": 60,                         // how many minutes between sync cycles
    "StartupRegistryKey": "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run",  // registry key used for startup entries
    "RegistryEntryPrefix": "Orch_"                     // prefix added to our startup entry names
  }
}
