// =====================================================================================
// FILE PURPOSE (in plain terms):
//   Settings for the operator console. The one value you MUST set is ControlRepoPath —
//   the folder where you cloned your control repo. Everything else has sane defaults.
//   (JSON forbids comments, but .NET's config reader ignores // comments, so they're OK.)
// =====================================================================================
{
  "Console": {
    "ControlRepoPath": "",              // REQUIRED: local path to your cloned control repo (holds manifest.json)
    "Remote": "origin",                 // git remote name to fetch from / push to
    "MainBranch": "main",               // branch holding manifest.json + fleet.json
    "FleetStateBranch": "fleet-state",  // branch the agents commit their heartbeats to
    "OpenBrowser": true                 // open the web UI automatically on start
  },
  "Urls": "http://localhost:5080"       // where the local web UI listens
}
